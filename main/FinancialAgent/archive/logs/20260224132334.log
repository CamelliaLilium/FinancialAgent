```python
import random
import tkinter as tk

# 简单的猜数字游戏
number_to_guess = random.randint(1, 100)

def check_guess():
    global number_to_guess
    try:
        guess = int(entry.get())
        if guess < number_to_guess:
            result_label.config(text="你猜的数字太小了，再试一次！")
        elif guess > number_to_guess:
            result_label.config(text="你猜的数字太大了，再试一次！")
        else:
            result_label.config(text="恭喜你，猜对了！")
    except ValueError:
        result_label.config(text="请输入一个有效的整数。")

# 创建主窗口
root = tk.Tk()
root.title("猜数字游戏")
root.geometry("300x200")

# 创建标签
welcome_label = tk.Label(root, text="欢迎来到猜数字游戏！")
welcome_label.pack(pady=10)

instruction_label = tk.Label(root, text="我心中想了一个1到100之间的数字，请你来猜猜看。")
instruction_label.pack(pady=5)

# 创建输入框
entry = tk.Entry(root)
entry.pack(pady=10)

# 创建按钮
guess_button = tk.Button(root, text="猜测", command=check_guess)
guess_button.pack(pady=5)

# 创建结果标签
result_label = tk.Label(root, text="")
result_label.pack(pady=5)

# 运行主循环
root.mainloop()
```

